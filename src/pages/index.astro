          <p data-impact-driver>{impactMetrics[0].driver}</p>
          <p class="outcome" data-impact-detail>{impactMetrics[0].detail}</p>
        </aside>
      </section>

      <section class="stories" id="stories" aria-labelledby="stories-title">
