</html>

<script>
  const cards = Array.from(document.querySelectorAll("[data-metric-card]"));
  const value = document.querySelector("[data-impact-value]");
  const label = document.querySelector("[data-impact-label]");
  const driver = document.querySelector("[data-impact-driver]");
  const detail = document.querySelector("[data-impact-detail]");

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      cards.forEach((item) => item.classList.remove("active"));
      card.classList.add("active");

      if (value) value.textContent = card.dataset.value || "";
      if (label) label.textContent = card.dataset.label || "";
      if (driver) driver.textContent = card.dataset.driver || "";
      if (detail) detail.textContent = card.dataset.detail || "";
    });
  });
</script>

